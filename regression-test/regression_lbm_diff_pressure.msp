do_domain:
  - domain:
     bounds: [[0,0,0],[0.1,0.1,0.1]]
     cell_dims: [ 30, 30, 30 ]
     periodic: [false, true, false]

set_lbm_parameters:
  - lbm_parameters:
     Fext: [0,0,0]
     nuth: 1e-4

pre_stream_bcs:
  - pre_bounce_back
  - wall_bounce_back

set_obstacles:
  - register_solid_wall:
     id: 0
     bounds: [[0.048,0,0.06],[0.052,0.1,0.1]]
  - register_solid_wall:
     id: 1
     bounds: [[0.048,0,0],[0.052,0.1,0.04]]

set_distribution:
  - set_distributions:
     value: 1.5
     bounds: [[0,0,0], [0.048,1,1]]

post_stream_bcs:
  - post_bounce_back

checker_op:
  - check_macro_quantities:
     density: 29124
     tol: 0.1
     vmin: 0.00
     vmax: 1.00e-16

global:
   simulation_paraview_freq: -1
   simulation_end_iteration: 100

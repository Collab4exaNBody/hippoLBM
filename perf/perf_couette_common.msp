set_lbm_parameters:
  - lbm_parameters:
     Fext: [0,0,0]
     nuth: 1e-2

boundary_conditions:
  - neumann:
     U: [0.001,0,0]
     regions: [plan_xy_l]
  - neumann:
     U: [0,0,0]
     regions: [plan_xy_0]

global:
   simulation_paraview_freq: -1
   simulation_print_log_freq: 100 # 100
   simulation_end_iteration: 1000

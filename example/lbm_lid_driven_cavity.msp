do_domain:
  - domain:
     bounds:    [ [0 m, 0 m, 0 m],[0.01 m, 0.01 m,  0.00025 m] ]
     cell_dims: [ 400 , 400 , 10 ]
     periodic:  [ false, false, true ]

set_lbm_parameters:
  - lbm_parameters:
     Fext: [0,0,0]
     nuth: 1e-5  # m2.s-1
     tau: 0.7

post_stream_bcs:
  - lid_driven_cavity:  ## need to be called after bounce back
     U: [1, 0.0, 0]  ## Re : 1000   
     regions: [plan_xz_l]
  - lid_driven_cavity:  ## need to be called after bounce back
     U: [0, 0.0, 0]  ## Re : 1000   
     regions: [plan_xz_0, plan_yz_0, plan_yz_l]


collision: bgk # or bgk

global:
   simulation_print_log_freq: 100
   simulation_paraview_freq: 1000
   simulation_end_iteration: 70000
   output_directory: "LidDrivenCavityDir"
